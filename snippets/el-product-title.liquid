<style>
  .title-{{ block.id }} { margin-bottom: {{ block.settings.margin_desktop }}px }
  @media (max-width: 980px) {
    .title-{{ block.id }} { margin-bottom: {{ block.settings.margin_mobile }}px }
  }
</style>

<h2 class="product-offer__info-title section-heading title-{{ block.id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank %}
    {{ block.settings.title }}
  {% else %}
    {{ product.title }}
  {% endif %}
</h2>