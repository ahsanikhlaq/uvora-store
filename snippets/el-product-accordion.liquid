<style>
  .accordion-{{ block.id }} { margin-bottom: {{ block.settings.margin_desktop }}px }
  @media (max-width: 980px) {
    .accordion-{{ block.id }} { margin-bottom: {{ block.settings.margin_mobile }}px }
  }
</style>

<div class="product-offer__acc-item faq-accordion__item accordion-{{ block.id }}" {{ block.shopify_attributes }}>
  <h4 class="product-offer__acc-item-title faq-accordion__item-title section-description">
    <span>{{ block.settings.title }}</span>
    {% render 'el-icon', icon: 'circle-plus', class: 'faq-icon icon-plus' %}
    {% render 'el-icon', icon: 'circle-minus', class: 'faq-icon icon-minus' %}
  </h4>
  <div class="product-offer__acc-item-description faq-accordion__item-description section-description">
    {{ block.settings.content }}
  </div>
</div>