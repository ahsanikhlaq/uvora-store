<style>
  .description-{{ block.id }} { margin-bottom: {{ block.settings.margin_desktop }}px }
  @media (max-width: 980px) {
    .description-{{ block.id }} { margin-bottom: {{ block.settings.margin_mobile }}px }
  }
</style>

<div class="product-offer__info-description section-description description-{{ block.id }}" {{ block.shopify_attributes }}>
  {% if block.settings.description != blank %}
    {{ block.settings.description }}
  {% else %}
    {{ product.description }}
  {% endif %}
</div>