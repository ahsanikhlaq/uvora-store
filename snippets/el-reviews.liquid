<style>
  .reviews-{{ block.id }} { margin-bottom: {{ block.settings.margin_desktop }}px }
  @media (max-width: 980px) {
    .reviews-{{ block.id }} { margin-bottom: {{ block.settings.margin_mobile }}px }
  }
</style>

<p class="product-offer__info-reviews el-svg section-description reviews-{{ block.id }}" {{ block.shopify_attributes }}>
  {% render 'el-icon', icon: 'stars' %}
  <span>{{ block.settings.reviews }}</span>
</p>