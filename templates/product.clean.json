        "custom_liquid": "<style>\n    /* --------------------------------------\n       BASE STYLES: Define font, colors, and layout structure\n       -------------------------------------- */\n    .remineralizing-gum-section {\n\n        max-width: 900px;\n        margin: 0 auto;\n        font-family: \"Montserat\", sans-serif;\n        ;\n    }\n\n    /* Header Styling */\n    .timeline-header {\n        text-align: center;\n        margin-bottom: 50px;\n    }\n\n    .timeline-header h2 {\n        font-size: 40px;\n        margin: 0;\n        padding: 0;\n        line-height: 1.4;\n        font-weight: 400;\n    }\n\n\n    /* --------------------------------------\n       TIMELINE CONTAINER & LINE\n       -------------------------------------- */\n    .timeline-container {\n        border: 2px solid #B4D014;\n        padding: 20px;\n        border-radius: 20px;\n        position: relative;\n    }\n\n    /* The main vertical line */\n    .timeline-container::before {\n        content: '';\n        position: absolute;\n        top: 20px;\n        left: 36px;\n        width: 4px;\n        background-color: #B4D014;\n        bottom: 0;\n        border-radius: 2px;\n        bottom: 20px;\n    }\n\n    /* --------------------------------------\n       MILESTONE ITEM STYLES\n       -------------------------------------- */\n\n    .milestone-content {\n        display: flex;\n        gap: 20px;\n        padding-bottom: 30px;\n\n    }\n    .milestone-content:last-child {\n        padding-bottom: 0px;\n\n    }\n\n    /* Milestone content card */\n\n    .f-width {\n        display: flex;\n    }\n\n    ._icon {\n        width: 38px;\n        height: 38px;\n        background-color: #ffffff;\n        /* White center */\n        border: 4px solid #B4D014;\n        /* Accent Teal Border */\n        border-radius: 50%;\n        z-index: 10;\n        box-sizing: border-box;\n        display: flex;\n        justify-content: center;\n        align-items: center;\n    }\n\n    .dot {\n        width: 16px;\n        height: 16px;\n        background-color: #B4D014;\n        /* Solid Accent Teal */\n        border-radius: 50%;\n        z-index: 11;\n    }\n\n    /* Time period tag (The rounded pill box) */\n    .milestone-tag {\n        display: inline-block;\n        background-color: #B4D014;\n        color: #ffffff;\n        font-weight: 700;\n        padding: 8px 20px;\n        border-radius: 9999px;\n        /* Fully rounded corners */\n        margin-bottom: 15px;\n        font-size: 14px;\n        text-transform: uppercase;\n    }\n\n    .milestone-title {\n        font-size: 18px;\n        font-weight: 700;\n        color: #000;\n        line-height: 1.4;\n        text-transform: uppercase;\nmargin: 0px 0px 5px 0px;\n    }\n\n    .milestone-description {\n        font-size: 16px;\n        color: rgba(0, 0, 0, 0.85);\n        margin: 0;\n        line-height: 1.4;\n        font-family: \"DM Sans\", sans-serif;\n    }\n\n    /* Last milestone needs no bottom margin/padding */\n    .timeline-milestone:last-child {\n        margin-bottom: 0;\n        padding-bottom: 0;\n    }\n\n\n\n\n\n\n    /* Small optimization for mobile readability */\n    @media (max-width: 767px) {\n        .remineralizing-gum-section {\n            padding: 10px 15px;\n        }\n\n        .timeline-header {\n            text-align: center;\n            margin-bottom: 30px;\n        }\n\n        .milestone-tag {\n            font-size: 12px;\n            padding: 5px 16px;\n        }\n\n        .milestone-title {\n            font-size: 18px;\n\n        }\n\n        .milestone-description {\n            font-size: 15px;\nfont-weight: 400;\n        }\n\n        .timeline-header h2 {\n            font-size: 30px;\n\n        }\n\n        .timeline-container {\n\n            padding: 20px 10px;\n\n        }\n\n        .timeline-container::before {\n            left: 26px;\n        }\n\n        ._icon {\n            width: 34px;\n            height: 34px;\n\n        }\n\n        .dot {\n            width: 14px;\n            height: 14px;\n\n        }\n\n         .milestone-content {\n        padding-bottom: 20px;\n\n    }\n\n    }\n</style>\n\n<div class=\"remineralizing-gum-section\">\n    <div class=\"timeline-header\">\n        <h2>Your 21-Day Transformation:</h2>\n    </div>\n\n    <div class=\"timeline-container\">\n        <!-- Milestone 1: Months 1–2 -->\n        <div class=\"timeline-milestone\">\n            <!-- 1st -->\n            <div class=\"milestone-content\">\n                <div class=\"f-width\">\n                    <div class=\"_icon\">\n                        <div class=\"dot\">\n                            <div></div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"texts\">\n                    <div class=\"milestone-tag\">Days 1–3</div>\n                    <h3 class=\"milestone-title\">Your Cleanse Begins</h3>\n                    <p class=\"milestone-description\">More frequent bathroom trips show your body is flushing out toxins.\n                       \n\n                    </p>\n                </div>\n            </div>\n            <!-- 2nd -->\n            <div class=\"milestone-content\">\n                <div class=\"f-width\">\n                    <div class=\"_icon\">\n                        <div class=\"dot\">\n                            <div></div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"texts\">\n                    <div class=\"milestone-tag\">Days 4–10</div>\n                    <h3 class=\"milestone-title\">Relief You Can Feel</h3>\n                    <p class=\"milestone-description\">Your stomach feels much lighter, and you notice less\n                        hair falling out with a renewed sense of vitality. </p>\n                </div>\n            </div>\n            <!-- 3rd -->\n            <div class=\"milestone-content\">\n                <div class=\"f-width\">\n                    <div class=\"_icon\">\n                        <div class=\"dot\">\n                            <div></div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"texts\">\n                    <div class=\"milestone-tag\">Days 11–20</div>\n                    <h3 class=\"milestone-title\">Energy & Glow Restored\n                    </h3>\n                    <p class=\"milestone-description\">You wake up\n                        and power through the day without caffeine. Your skin starts to glow — clearer\n                        than it's been in years.\n\n                    </p>\n                </div>\n            </div>\n            <!-- 4th -->\n            <div class=\"milestone-content\">\n                <div class=\"f-width\">\n                    <div class=\"_icon\">\n                        <div class=\"dot\">\n                            <div></div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"texts\">\n                    <div class=\"milestone-tag\">\n                        Days 21+\n                    </div>\n                    <h3 class=\"milestone-title\">Your Total Reset\n\n                    </h3>\n                    <p class=\"milestone-description\">Your system feels balanced, and you\n                        finally feel like yourself again. Uvora continues to protect your liver for lasting wellness.\n                    </p>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>",
        "color_scheme": "",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
