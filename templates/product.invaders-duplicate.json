    "c0ef23cf-5481-4b47-9b78-3c28134c079a": {
      "type": "collapsible-content",
      "blocks": {
        "template--15124688076883__c0ef23cf-5481-4b47-9b78-3c28134c079a-collapsible_row-1": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What is Uvora Milk Thistle?",
            "icon": "none",
            "row_content": "<p>A natural digestive cleanse supplement that gently supports liver health and helps eliminate built-up waste. It works with only natural ingredients while boosting energy levels and reducing bloating!</p>",
            "page": ""
          }
        },
        "template--15124688076883__c0ef23cf-5481-4b47-9b78-3c28134c079a-collapsible_row-2": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How does it work?",
            "icon": "none",
            "row_content": "<p>This formula supports liver and digestion by promoting detox and reducing inflammation. Milk Thistle and Turmeric aid cleansing, while Inositol and Pueraria boost metabolism for smoother digestion and steady energy.</p>",
            "page": ""
          }
        },
        "collapsible_row_JcJTnW": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How do I use it?",
            "icon": "none",
            "row_content": "<p>Take 1 capsule daily with water, preferably with a meal. For added support, take at the same time each day to keep your system balanced!</p>",
            "page": ""
          }
        },
        "collapsible_row_frrFPX": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How long does it take to see results?",
            "icon": "none",
            "row_content": "<p>Most people notice changes within days, but results build with consistent use:</p><p><strong>Days 1 to 5</strong> — lighter digestion, less bloating, steadier energy<br/><br/><strong>Week 2 to 3</strong> — clearer skin, better metabolism, improved balance<br/><br/><strong>Week 4 and beyond</strong> — feeling lighter, refreshed, and fully transformed</p><p>Consistent use gives the best results.</p>",
            "page": ""
          }
        },
        "template--15124688076883__c0ef23cf-5481-4b47-9b78-3c28134c079a-collapsible_row-4": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How can I get in contact?",
            "icon": "none",
            "row_content": "<p>Please contact us for support or questions at: support@getuvora.com</p>",
            "page": ""
          }
        },
        "collapsible_row_4h8fzT": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How fast is shipping?",
            "icon": "none",
            "row_content": "<p>Orders are processed within 1-2 business days and delivered within 7-12 business days.<br/>If you’re not 100% satisfied, you can return it within <strong>90 days</strong> with zero questions asked.</p>",
            "page": ""
          }
        }
