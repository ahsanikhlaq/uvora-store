{%- comment -%}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  SECTION: Site Footer
  Purpose: Dispay footer contents
  Last updated: March 2026
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
{%- endcomment -%}

{% liquid
  assign bg_color = section.settings.bg_color
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  .section-{{ section.id }}-bg { background: {{ bg_color }} }
  @media screen and (max-width: 980px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
{%- endstyle -%}

{{ 'el-site-footer.css' | asset_url | stylesheet_tag }}

<section class="site-footer section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="site-footer__wrapper section-wrapper section-{{ section.id }}-padding section-{{ section.id }}-bg">
    <div class="site-footer__container section-container">
      <div class="site-footer__contents">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'logo' %}
              <a href="{{ routes.root_url }}" class="site-footer__logo">
                <img src="{{ block.settings.logo | image_url }}" width="100%" height="auto" alt="{{ block.settings.logo | default: 'footer-logo' }}" fetchpriority="low" loading="lazy" />
              </a>
            {% when 'contact-info' %}
              <div class="site-footer__contact">
                <p class="site-footer__contact-title section-description">{{ block.settings.title }}</p>
                <a href="mailto:{{ block.settings.email }}" class="site-footer__contact-email section-description">{{ block.settings.email }}</a>
                <div class="site-footer__contact-description section-description">
                  {{ block.settings.additional_info }}
                </div>
              </div>
            {% when 'description' %}
              <div class="site-footer__description section-description">
                {{ block.settings.description }}
              </div>
            {% when 'footnotes' %}
              <div class="site-footer__footnotes">
                <img src="{{ block.settings.payments | image_url }}" width="100%" height="auto" alt="{{ block.settings.payments | default: 'payment-options' }}" fetchpriority="low" loading="lazy" />
                <p class="section-description">© {{ 'now' | date: '%Y' }}, {{ shop.name }}</p>
              </div>
            {% when 'menu-mobile' %}
              <div class="site-footer__menu mobile-display">
                {% assign menu = linklists[block.settings.menu] %}

                <div class="site-footer__menu-item">
                  <p class="site-footer__menu-item-title section-descripion">
                    {% if block.settings.title != blank %}
                      {{ block.settings.title }}
                    {% else %}
                      {{ menu.title }}
                    {% endif %}
                  </p>
                  <ul class="site-footer__menu-lists section-descripion">
                    {% for link in menu.links %}
                      <li>
                        <a href="{{ link.url }}">{{ link.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>

      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'menu' %}
            <div class="site-footer__menu desktop-display">
              {% assign menu = linklists[block.settings.menu] %}

              <div class="site-footer__menu-item">
                <p class="site-footer__menu-item-title section-descripion">
                  {% if block.settings.title != blank %}
                    {{ block.settings.title }}
                  {% else %}
                    {{ menu.title }}
                  {% endif %}
                </p>
                <ul class="site-footer__menu-lists section-descripion">
                  {% for link in menu.links %}
                    <li>
                      <a href="{{ link.url }}">{{ link.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Site Header",
  "tag": "footer",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Background Color",
      "default": "linear-gradient(#B4D014, #9DB511)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 20
    },
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
      ]
    },
    {
      "type": "contact-info",
      "name": "Contact Info",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "lorem ipsum"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email",
          "default": "support@getuvora.com"
        },
        {
          "type": "richtext",
          "id": "additional_info",
          "label": "Additional Info",
          "default": "<p>lorem ipsum dolor</p>"
        }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "lorem ipsum"
        }
      ]
    },
    {
      "type": "footnotes",
      "name": "Footnotes",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "payments",
          "label": "Payments",
        }
      ]
    },
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Menu",
          "info": "leave blank if not needed"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "menu-mobile",
      "name": "Menu Mobile",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Menu",
          "info": "leave blank if not needed"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Site Footer",
      "category": "Ecomlanders"
    }
  ]
}
{% endschema %}
