{%- endcomment -%}

{% liquid
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign btn_text = section.settings.btn_text
  assign btn_link = section.settings.btn_link
  assign money_back = section.settings.money_back
  assign feat_img = section.settings.feat_img
  assign feat_img_decor = section.settings.feat_img_decor
  assign bg_color = section.settings.bg_color
  assign bg_color_inner = section.settings.bg_color_inner
  assign bg_img = section.settings.bg_img
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  .section-{{ section.id }}-bg {
    background-color: {{ bg_color }};
    {% if bg_img != blank %}
    background-image: url({{ bg_img | image_url }});
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    background-attachment: fixed;
    {% endif %}
  }
  .section-{{ section.id }}-bg-inner { background: {{ bg_color_inner }} }
  .section-{{ section.id }} .money-back__container-inner:after { background-color: {{ bg_color }} }

  @media screen and (max-width: 980px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
    {% if bg_img != blank %}
      .section-{{ section.id }}-bg { background-attachment: unset; }
    {% endif %}
  }
{%- endstyle -%}

{{ 'el-money-back.css' | asset_url | stylesheet_tag }}

<section class="money-back section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="money-back__wrapper section-wrapper section-{{ section.id }}-padding section-{{ section.id }}-bg">
    <div class="money-back__container section-container">
      <div class="money-back__container-inner section-{{ section.id }}-bg-inner">
        <div class="money-back__info-contents">
          <h2 class="money-back__heading section-heading">{{ heading }}</h2>
          <p class="money-back__description section-description">{{ description }}</p>
          {% if btn_text != blank %}
            <div class="money-back__button section-button">
              <a href="{{ btn_link }}">{{ btn_text }}</a>
            </div>
          {% endif %}
        </div>
        {% if money_back != blank %}
          <div class="money-back__mny-img">
            <img src="{{ money_back | image_url }}" width="100%" height="auto" alt="{{ money_back.alt | default: 'money-back-img' }}" fetchpriority="low" loading="lazy" />
          </div>
        {% endif %}
        <div class="money-back__feat-container desktop-display">
          {% if feat_img != blank %}
            <img src="{{ feat_img | image_url }}" width="100%" height="auto" class="money-back__feat-img money-feat" alt="{{ feat_img.alt | default: 'money-feat-img' }}" fetchpriority="low" loading="lazy" />
          {% endif %}
          {% if feat_img_decor != blank %}
            <img src="{{ feat_img_decor | image_url }}" width="100%" height="auto" class="money-back__feat-img money-feat-addon" alt="{{ feat_img_decor.alt | default: 'money-feat-img-addon' }}" fetchpriority="low" loading="lazy" />
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Money Back",
  "settings": [    
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "lorem ipsum"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "lorem ipsum dolor"
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Try Uvora Risk-Free"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Featured Images"
    },
    {
      "type": "image_picker",
      "id": "money_back",
      "label": "Money Back",
    },
    {
      "type": "image_picker",
      "id": "feat_img",
      "label": "Featured Image",
    },
    {
      "type": "image_picker",
      "id": "feat_img_decor",
      "label": "Featured Image (decor)",
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F4F3E8"
    },
    {
      "type": "color_background",
      "id": "bg_color_inner",
      "label": "Background Color (Inner)",
      "default": "linear-gradient(#9EB711, #A3BC12)"
    },
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Background Image",
      "info": "leave blank if not needed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 40
    },
  ],
  "presets": [
    {
      "name": "Money Back",
      "category": "Ecomlanders"
    }
  ]
}
{% endschema %}
