{%- comment -%}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  SECTION: Step Progress
  Purpose: Display step counts
  Last updated: March 2026
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
{%- endcomment -%}

{% liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign feat_img = section.settings.feat_img
  assign bg_color = section.settings.bg_color
  assign bg_color_inner= section.settings.bg_color_inner
  assign bg_img = section.settings.bg_img
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  .section-{{ section.id }}-bg {
    background-color: {{ bg_color }};
    {% if bg_img != blank %}
    background-image: url({{ bg_img | image_url }});
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    {% endif %}
  }
  .section-{{ section.id }}-bg-inner { background-color: {{ bg_color_inner }} }
  @media screen and (max-width: 980px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
{%- endstyle -%}

{{ 'el-step-progress.css' | asset_url | stylesheet_tag }}

<section class="step-progress section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="step-progress__wrapper section-wrapper section-{{ section.id }}-padding section-{{ section.id }}-bg">
    <div class="step-progress__container section-container section-{{ section.id }}-bg-inner">
      <div class="step-progress__info-container">
        <p class="step-progress__eyebrow section-description">{{ eyebrow }}</p>
        <h2 class="step-progress__heading section-heading">{{ heading }}</h2>
        <p class="step-progress__description section-description">{{ description }}</p>
        <div class="step-progress__divider"></div>

        <div class="step-progress__contents">
          {% for block in section.blocks %}
            <div class="step-progress__item">
              <p class="step-progress__item-count">0{{ forloop.index }}</p>
              <p class="step-progress__item-title section-description">
                <span>{{ block.settings.title }}</span>
                <img src="{{ block.settings.icon | image_url }}" width="100%" height="auto" alt="{{ block.settings.icon.alt | default: 'step-icon' }}" fetchpriority="low" loading="lazy" />
              </p>
              <p class="step-progress__item-description section-description">{{ block.settings.content }}</p>
            </div>
          {% endfor %}
        </div>
      </div>

      <div class="step-progress__img-container">
        <img src="{{ feat_img | image_url }}" width="100%" height="auto" alt="{{ feat_img.alt | default: 'step-feat' }}" fetchpriority="low" loading="lazy" />
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Step Progress",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "lorem ipsum"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "lorem ipsum"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "lorem ipsum dolor"
    },
    {
      "type": "image_picker",
      "id": "feat_img",
      "label": "Featured Image",
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F4F3E8"
    },
    {
      "type": "color",
      "id": "bg_color_inner",
      "label": "Background Color (Inner)",
      "default": "#FAFAF5"
    },
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Background Image",
      "info": "leave blank if not needed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 20
    },
  ],
  "blocks": [
    {
      "type": "step-item",
      "name": "Step Item",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "lorem ipsum"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Content",
          "default": "lorem ipsum dolor"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Step Progress",
      "category": "Ecomlanders"
    }
  ]
}
{% endschema %}