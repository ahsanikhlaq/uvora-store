{%- comment -%}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  SECTION: Progress Counter
  Purpose: Display progress items
  Last updated: March 2026
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
{%- endcomment -%}

{% liquid
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign bg_color = section.settings.bg_color
  assign bg_img = section.settings.bg_img
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  .section-{{ section.id }}-bg {
    background-color: {{ bg_color }};
    {% if bg_img != blank %}
      background-image: url({{ bg_img | image_url }});
      background-size: cover;
      background-repeat: no-repeat;
      background-position: center;
    {% endif %}
  }
  @media screen and (max-width: 980px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
{%- endstyle -%}

{{ 'el-progress-counter.css' | asset_url | stylesheet_tag }}

<section class="progress-counter section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="progress-counter__wrapper section-wrapper section-{{ section.id }}-padding section-{{ section.id }}-bg">
    <div class="progress-counter__container section-container">
      <h2 class="progress-counter__heading section-heading">{{ heading }}</h2>
      <p class="progress-counter__description section-description">{{ description }}</p>

      <div class="progress-counter__contents">
        {% for block in section.blocks %}
          <div class="progress-counter__item">
            <img src="{{ block.settings.image | image_url }}" width="100%" height="auto" alt="{{ block.settings.image.alt | default: 'counter-img' }}" fetchpriority="low" loading="lazy" />

            <div>
              <p class="progress-counter__item-counter section-heading"><span data-counter="{{ block.settings.count }}">0</span>{{ block.settings.symbol }}</p>
              <p class="progress-counter__item-content section-description">{{ block.settings.content }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script src="{{ "el-progress-counter.js" | asset_url }}" defer></script>

{% schema %}
{
  "name": "Progress Counter",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "lorem ipsum"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "label": "Description",
      "default": "lorem ipsum dolor"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#9EB711"
    },
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Background Image",
      "info": "leave if not needed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 40
    },
  ],
  "blocks": [
    {
      "type": "counter-item",
      "name": "Counter Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "number",
          "id": "count",
          "label": "Count",
          "default": 62
        },
        {
          "type": "text",
          "id": "symbol",
          "label": "Symbol",
          "default": "%"
        },
        {
          "type": "inline_richtext",
          "id": "content",
          "label": "Content",
          "default": "lorem ipsum dolor"
        }
      ]
    },
  ],
  "presets": [
    {
      "name": "Progress Counter",
      "category": "Ecomlanders"
    }
  ]
}
{% endschema %}
