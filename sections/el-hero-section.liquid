{%- comment -%}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  SECTION: Hero Section
  Purpose: Display hero contents
  Last updated: March 2026
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
{%- endcomment -%}

{% liquid
  assign rating = section.settings.rating
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign lists = section.settings.lists | strip | newline_to_br | split: '<br />'
  assign btn_text = section.settings.btn_text
  assign btn_link = section.settings.btn_link
  assign btn_footnotes = section.settings.btn_footnotes
  assign feat_img = section.settings.feat_img
  assign bg_color = section.settings.bg_color
  assign bg_img = section.settings.bg_img
  assign bg_color_inner = section.settings.bg_color_inner
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  .section-{{ section.id }}-bg {
    background-color: {{ bg_color }};
    {% if bg_img != blank %}
    background-image: url({{ bg_img | image_url }});
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    {% endif %}
  }
  .section-{{ section.id }}-bg-inner { background-color: {{ bg_color_inner }} }
  @media screen and (max-width: 580px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
{%- endstyle -%}

{{ 'el-hero-section.css' | asset_url | stylesheet_tag }}

<section class="hero-section section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="hero-section__wrapper section-wrapper section-{{ section.id }}-padding section-{{ section.id }}-bg">
    <div class="hero-section__container section-container section-{{ section.id }}-bg-inner">
      <div class="hero-section__info-content">
        <p class="hero-section__reviews section-description el-svg">
          {% render 'el-icon', icon: 'stars' %}
          <span>{{ rating }}</span>
        </p>
        <h1 class="hero-section__heading section-heading">{{ heading }}</h1>
        <p class="hero-section__description section-description">{{ description }}</p>
        <p class="hero-section__usps section-description el-svg">
          {% for list in lists %}
            <span>
              {% render 'el-icon', icon: 'check' %}
              {{ list }}
            </span>
          {% endfor %}
        </p>

        <div class="hero-section__button section-button">
          <a href="{{ btn_link }}">{{ btn_text }}</a>
          <p class="section-description el-svg">
            {% render 'el-icon', icon: 'shield' %}
            <span>{{ btn_footnotes }}</span>
          </p>
        </div>
      </div>

      <div class="hero-section__img-content">
        <img src="{{ feat_img | image_url }}" width="100%" height="auto" fetchpriority="high" loading="eager" alt="{{ feat_img | default: 'banner-feat' }}" />
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "rating",
      "label": "Rating",
      "default": "lorem ipsum"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "lorem ipsum dolor"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "lorem ipsum dolor"
    },
    {
      "type": "textarea",
      "id": "lists",
      "label": "Lists",
      "default": "lorem \nipsum",
      "info": "separate each item with an enter key"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "SUPPORT YOUR LIVER NOW →"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "btn_footnotes",
      "label": "Button Footnoes",
      "default": "lorem ipsum dolor"
    },
    {
      "type": "image_picker",
      "id": "feat_img",
      "label": "Featured Image"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F4F3E8"
    },
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Background Image",
      "info": "leave blank if not needed"
    },
    {
      "type": "color",
      "id": "bg_color_inner",
      "label": "Background Color (Inner)",
      "default": "#F2F0E8"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 30
    },
  ],
  "presets": [
    {
      "name": "Hero Section",
      "category": "Ecomlanders"
    }
  ]
}
{% endschema %}