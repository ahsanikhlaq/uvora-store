{%- comment -%}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  SECTION: Comparison Table
  Purpose: Display customer testimonials
  Last updated: March 2026
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
{%- endcomment -%}

{% liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign bg_color = section.settings.bg_color
  assign bg_img = section.settings.bg_img
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign btn_text = section.settings.btn_text
  assign btn_link = section.settings.btn_link
  assign btn_footnotes = section.settings.btn_footnotes
  assign feat_img = section.settings.feat_img
  assign feat_img2 = section.settings.feat_img2
  assign type = section.settings.type
  assign feat_mob = section.settings.feat_mob
%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  .section-{{ section.id }}-bg {
    background-color: {{ bg_color }};
    {% if bg_img != blank %}
    background-image: url({{ bg_img | image_url }});
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    background-attachment: fixed;
    {% endif %}
  }
  @media screen and (max-width: 980px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
    {% if bg_img != blank %}
      .section-{{ section.id }}-bg { background-attachment: unset; }
    {% endif %}
  }
{%- endstyle -%}

{{ 'el-comparison-table.css' | asset_url | stylesheet_tag }}

<section class="comparison-table section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="comparison-table__wrapper section-wrapper section-{{ section.id }}-padding section-{{ section.id }}-bg">
    <div class="comparison-table__container section-container version-{{ type }}">
      {% if eyebrow != blank %}
        <p class="comparison-table__eyebrow section-description">{{ eyebrow }}</p>
      {% endif %}
      <h2 class="comparison-table__heading section-heading">{{ heading }}</h2>

      <div class="comparison-table__contents">
        {% for block in section.blocks %}
          {% assign lists = block.settings.lists | strip | newline_to_br | split: '<br />' %}   
          <div class="comparison-table__list-column">
            <p class="comparison-table__col-title"></p>

            <ul class="comparison-table__list-contents section-description">
              {% for list in lists %}
                <li>{{ list }}</li>
              {% endfor %}
            </ul>
          </div>
          <div class="comparison-table__brand-column">
            <p class="comparison-table__col-title">
              <img src="{{ block.settings.logo | image_url }}" width="100%" height="auto" alt="{{ block.settings.logo.alt | default: 'tbl-logo' }}" fetchpriority="low" loading="lazy" />
            </p>

            <ul class="comparison-table__list-contents section-description">
              {% for list in lists %}
                <li>{% render 'el-icon', icon: "square-check" %}</li>
              {% endfor %}
            </ul>
          </div>
          <div class="comparison-table__other-column">
            <p class="comparison-table__col-title"><span>{{ block.settings.others }}</span></p>

            <ul class="comparison-table__list-contents section-description">
              {% for list in lists %}
                <li>{% render 'el-icon', icon: "square-x" %}</li>
              {% endfor %}
            </ul>
          </div>
        {% endfor %}
      </div>

      {% if btn_text != blank %}
        <div class="comparison-table__button section-button">
          <a href="{{ btn_link }}">{{ btn_text }}</a>
          <p class="section-description el-svg">
            {% render 'el-icon', icon: 'shield', color: "#F4F3E8" %}
            <span>{{ btn_footnotes }}</span>
          </p>
        </div>
      {% endif %}
    </div>

    {% if feat_img != blank %}
      <img src="{{ feat_img | image_url }}" width="100%" height="auto" class="comparison-table__feat-img comparison-feat-1 {% if feat_mob != blank %}desktop-display{% endif %}" alt="{{ feat_img.alt | default: 'table-feat-img' }}" fetchpriority="low" loading="lazy" />
    {% endif %}
    {% if feat_img2 != blank %}
      <img src="{{ feat_img2 | image_url }}" width="100%" height="auto" class="comparison-table__feat-img comparison-feat-2 desktop-display" alt="{{ feat_img2.alt | default: 'table-feat-img-2' }}" fetchpriority="low" loading="lazy" />
    {% endif %}
    {% if feat_mob != blank %}
      <img src="{{ feat_mob | image_url }}" width="100%" height="auto" class="comparison-table__feat-img comparison-feat-mob mobile-display" alt="{{ feat_mob.alt | default: 'table-feat-img-mob' }}" fetchpriority="low" loading="lazy" />
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Comparison Table",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "lorem ipsum"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "lorem ipsum"
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "SUPPORT YOUR LIVER NOW →"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "btn_footnotes",
      "label": "Button Footnoes",
      "default": "lorem ipsum dolor"
    },
    {
      "type": "header",
      "content": "Featured Images"
    },
    {
      "type": "image_picker",
      "id": "feat_img",
      "label": "Featured Image",
    },
    {
      "type": "image_picker",
      "id": "feat_img2",
      "label": "Featured Image 2",
    },
    {
      "type": "image_picker",
      "id": "feat_mob",
      "label": "Featured Image (mobile)",
      "info": "leave blank to display 1st image on mobile"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "select",
      "id": "type",
      "label": "Type",
      "options": [
        {
          "label": "Dark",
          "value": "dark"
        },
        {
          "label": "Light",
          "value": "light"
        }
      ],
      "default": "dark"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#A9C313"
    },
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Background Image",
      "info": "leave blank if not needed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 40
    },
  ],
  "blocks": [
    {
      "type": "table-contents",
      "name": "Table Contents",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo",
        },
        {
          "type": "text",
          "id": "others",
          "label": "Other",
          "default": "OTHER BRANDS"
        },
        {
          "type": "textarea",
          "id": "lists",
          "label": "Lists",
          "default": "lorem \nipsum \ndolor",
          "info": "separate each item with an enter key."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Table",
      "category": "Ecomlanders"
    }
  ]
}
{% endschema %}
