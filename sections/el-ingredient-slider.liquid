{%- comment -%}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  SECTION: Ingredient Slider
  Purpose: Display customer testimonials
  Last updated: March 2026
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
{%- endcomment -%}

{% liquid
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign bg_color = section.settings.bg_color
  assign bg_img = section.settings.bg_img
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign type = section.settings.type
%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  .section-{{ section.id }}-bg {
    background-color: {{ bg_color }};
    {% if bg_img != blank %}
    background-image: url({{ bg_img | image_url }});
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    background-attachment: fixed;
    {% endif %}
  }
  @media screen and (max-width: 980px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
    {% if bg_img != blank %}
      .section-{{ section.id }}-bg { background-attachment: unset; }
    {% endif %}
  }
{%- endstyle -%}

{{ 'el-ingredient-slider.css' | asset_url | stylesheet_tag }}

<section class="ingredient-slider section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="ingredient-slider__wrapper section-wrapper section-{{ section.id }}-padding section-{{ section.id }}-bg">
    <div class="ingredient-slider__container section-container version-{{ type }}">
      <h2 class="ingredient-slider__heading section-heading">{{ heading }}</h2>
      <p class="ingredient-slider__description section-description">{{ description }}</p>

      <div class="swiper ingredient-slider__contents section-slider">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide ingredient-slider__item">
              <div class="ingredient-slider__item-inner">
                <div class="ingredient-slider__item-image">
                  <img src="{{ block.settings.image | image_url }}" width="100%" height="auto" alt="{{ block.settings.image.alt | default: 'ingredient-img' }}" fetchpriority="low" loading="lazy" />
                </div>
                <div class="ingredient-slider__item-contents">
                  <p class="ingredient-slider__item-eyebrow section-description">{{ block.settings.eyebrow }}</p>
                  <p class="ingredient-slider__item-title section-description">{{ block.settings.title }}</p>
                  <p class="ingredient-slider__item-content section-description">{{ block.settings.content }}</p>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
        <div class="ingredient-slider__buttons">
          <div class="swiper-button-prev-ingredient swiper-btn-ingredient swiper-btn">
            {% render 'el-icon', icon: 'circle-arrow-left' %}
          </div>
          <div class="swiper-pagination-col"></div>
          <div class="swiper-button-next-ingredient swiper-btn-ingredient swiper-btn">
            {% render 'el-icon', icon: 'circle-arrow-right' %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ "el-ingredient-slider.js" | asset_url }}" defer></script>

{% schema %}
{
  "name": "Ingredient Slider",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "lorem ipsum"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "lorem ipsum"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "select",
      "id": "type",
      "label": "Type",
      "options": [
        {
          "label": "Dark",
          "value": "dark"
        },
        {
          "label": "Light",
          "value": "light"
        }
      ],
      "default": "dark"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#A9C313"
    },
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Background Image",
      "info": "leave blank if not needed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 40
    },
  ],
  "blocks": [
    {
      "type": "ingredient-item",
      "name": "Ingredient Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "lorem ipsum"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "lorem ipsum"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Content",
          "default": "lorem ipsum"
        },
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredient Slider",
      "category": "Ecomlanders"
    }
  ]
}
{% endschema %}