{%- comment -%}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  SECTION: Testimonial Slider
  Purpose: Display customer testimonials
  Last updated: March 2026
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
{%- endcomment -%}

{% liquid
  assign heading = section.settings.heading
  assign bg_color = section.settings.bg_color
  assign bg_img = section.settings.bg_img
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  .section-{{ section.id }}-bg {
    background-color: {{ bg_color }};
    {% if bg_img != blank %}
    background-image: url({{ bg_img | image_url }});
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    background-attachment: fixed;
    {% endif %}
  }
  @media screen and (max-width: 980px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
    {% if bg_img != blank %}
      .section-{{ section.id }}-bg { background-attachment: unset; }
    {% endif %}
  }
{%- endstyle -%}

{{ 'el-testimonial-slider.css' | asset_url | stylesheet_tag }}

<section class="testimonial-slider section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="testimonial-slider__wrapper section-wrapper section-{{ section.id }}-padding section-{{ section.id }}-bg">
    <div class="testimonial-slider__container section-container">
      <h2 class="testimonial-slider__heading section-heading">{{ heading }}</h2>

      <div class="swiper testimonial-slider__contents section-slider">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide testimonial-slider__item">
              <div class="testimonial-slider__item-inner">
                {% render 'el-icon', icon: "trust-stars" %}
                <p class="testimonial-slider__item-content section-description">{{ block.settings.content }}</p>
                {% assign tags = block.settings.tags | strip | newline_to_br | split: '<br />' %}
                <p class="testimonial-slider__item-tag section-description">
                  {% for tag in tags %}
                    <span>{{ tag }}</span>
                  {% endfor %}
                </p>
                <p class="testimonial-slider__item-name section-description el-svg">
                  {% render 'el-icon', icon: "check" %}
                  <span>{{ block.settings.customer_name }}</span>
                </p>
              </div>
            </div>
          {% endfor %}
        </div>
        <div class="testimonial-slider__buttons">
          <div class="swiper-button-prev-testimonial swiper-btn-testimonial swiper-btn">
            {% render 'el-icon', icon: 'circle-arrow-left' %}
          </div>
          <div class="swiper-pagination-col"></div>
          <div class="swiper-button-next-testimonial swiper-btn-testimonial swiper-btn">
            {% render 'el-icon', icon: 'circle-arrow-right' %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ "el-testimonial-slider.js" | asset_url }}" defer></script>

{% schema %}
{
  "name": "Testimonial Slider",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "lorem ipsum"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#9EB711"
    },
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Background Image",
      "info": "leave blank if not needed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 40
    },
  ],
  "blocks": [
    {
      "type": "testimonial-item",
      "name": "Testimonial Item",
      "settings": [
        {
          "type": "textarea",
          "id": "content",
          "label": "Content",
          "default": "lorem ipsum"
        },
        {
          "type": "textarea",
          "id": "tags",
          "label": "Tags",
          "default": "lorem \nipsum",
          "info": "separate each item with an enter key"
        },
        {
          "type": "inline_richtext",
          "id": "customer_name",
          "label": "Custom Name",
          "default": "lorem ipsum"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial Slider",
      "category": "Ecomlanders"
    }
  ]
}
{% endschema %}
