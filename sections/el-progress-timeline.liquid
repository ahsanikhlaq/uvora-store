{%- comment -%}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  SECTION: Progress Timeline
  Purpose: Weekly timeline
  Last updated: March 2026
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
{%- endcomment -%}

{% liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign notes = section.settings.notes
  assign btn_text = section.settings.btn_text
  assign btn_link = section.settings.btn_link
  assign btn_footnotes = section.settings.btn_footnotes
  assign bg_color = section.settings.bg_color
  assign bg_img = section.settings.bg_img
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  .section-{{ section.id }}-bg {
    background-color: {{ bg_color }};
    {% if bg_img != blank %}
      background-image: url({{ bg_img | image_url }});
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
  }
  @media screen and (max-width: 980px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
{%- endstyle -%}

{{ 'el-progress-timeline.css' | asset_url | stylesheet_tag }}

<section class="progress-timeline section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="progress-timeline__wrapper section-wrapper section-{{ section.id }}-padding section-{{ section.id }}-bg">
    <div class="progress-timeline__container section-container">
      <p class="progress-timeline__eyebrow section-description">{{ eyebrow }}</p>
      <h2 class="progress-timeline__heading section-heading">{{ heading }}</h2>

      <div class="progress-timeline__contents">
        {% for block in section.blocks %}
          <div class="progress-timeline__item">
            <div class="progress-timeline__item-content">
              <div class="progress-timeline__item-content-img">
                <img src="{{ block.settings.image | image_url }}" width="100%" height="auto" alt="{{ block.settings.image.alt | default: 'journey-img' }}" fetchpriority="low" loading="lazy" />
              </div>

              <p class="progress-timeline__item-title section-description">{{ block.settings.title }}</p>

              {% assign lists = block.settings.lists | strip | newline_to_br | split: '<br />' %}    
              <ul class="progress-timeline__item-list section-description">
                <div class="progress-timeline__indicator mobile-display">
                  <span></span>
                </div>
                {% for list in lists %}
                  <li class="el-svg">
                    {% render 'el-icon', icon: 'check' %}
                    <span>{{ list }}</span>
                  </li>
                {% endfor %}
              </ul>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if notes != blank %}
        <p class="progress-timeline__notes section-description">{{ notes }}</p>
      {% endif %}

      {% if btn_text != blank %}
        <div class="progress-timeline__button section-button">
          <a href="{{ btn_link }}">{{ btn_text }}</a>
          <p class="section-description el-svg">
            {% render 'el-icon', icon: 'shield' %}
            <span>{{ btn_footnotes }}</span>
          </p>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<script src="{{ "el-progress-timeline.js" | asset_url }}" defer></script>

{% schema %}
{
  "name": "Progress Timeline",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "lorem ipsum"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "lorem ipsum"
    },
    {
      "type": "textarea",
      "id": "notes",
      "label": "Notes",
      "default": "lorem ipsum"
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "SUPPORT YOUR LIVER NOW →"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "btn_footnotes",
      "label": "Button Footnoes",
      "default": "lorem ipsum dolor"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#EEEDDD"
    },
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Background Image",
      "info": "leave blank if not needed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 40
    },
  ],
  "blocks": [
    {
      "type": "timeline-item",
      "name": "Timeline Item",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Title",
          "default": "lorem ipsum"
        },
        {
          "type": "textarea",
          "id": "lists",
          "label": "Lists",
          "default": "lorem \nipsum",
          "info": "separate each item with an _enter_ key"
        },
      ]
    }
  ],
  "presets": [
    {
      "name": "Progress Timeline",
      "category": "Ecomlanders"
    }
  ]
}
{% endschema %}