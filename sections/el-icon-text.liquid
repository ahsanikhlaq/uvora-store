{%- comment -%}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  SECTION: Icon Text
  Purpose: Display icon + info
  Last updated: March 2026
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
{%- endcomment -%}

{% liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign feat_img = section.settings.feat_img
  assign feat_img2 = section.settings.feat_img2
  assign btn_text = section.settings.btn_text
  assign btn_link = section.settings.btn_link
  assign btn_footnotes = section.settings.btn_footnotes
  assign bg_color = section.settings.bg_color
  assign bg_img = section.settings.bg_img
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  .section-{{ section.id }}-bg {
    background-color: {{ bg_color }};
    {% if bg_img != blank %}
    background-image: url({{ bg_img | image_url }});
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    {% endif %}
  }
  @media screen and (max-width: 980px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
{%- endstyle -%}

{{ 'el-icon-text.css' | asset_url | stylesheet_tag }}

<section class="icon-text section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="icon-text__wrapper section-wrapper section-{{ section.id }}-padding section-{{ section.id }}-bg">
    <div class="icon-text__container section-container">
      <p class="icon-text__eyebrow section-description">{{ eyebrow }}</p>
      <h2 class="icon-text__heading section-heading">{{ heading }}</h2>

      <div class="icon-text__contents">
        {% for block in section.blocks %}
          <div class="icon-text__item">
            <div class="icon-text__item-img">
              <img src="{{ block.settings.icon | image_url }}" width="100%" height="auto" alt="{{ block.settings.icon.alt | default: 'block-icon' }}" fetchpriority="low" loading="lazy" />
            </div>
            <p class="icon-text__content section-description">{{ block.settings.content }}</p>
          </div>
        {% endfor %}
      </div>

      {% if btn_text != blank %}
        <div class="icon-text__button section-button">
          <a href="{{ btn_link }}">{{ btn_text }}</a>
          <p class="section-description el-svg">
            {% render 'el-icon', icon: 'shield' %}
            <span>{{ btn_footnotes }}</span>
          </p>
        </div>
      {% endif %}

      <div class="icon-text__feats">
        {% if feat_img != blank %}
          <img src="{{ feat_img | image_url }}" width="100%" height="auto" class="icon-text__feat-img" alt="{{ feat_img.alt | default: 'feat-img' }}" fetchpriority="low" loading="lazy" />
        {% endif %}
        {% if feat_img2 != blank %}
          <img src="{{ feat_img2 | image_url }}" width="100%" height="auto" class="icon-text__feat-img" alt="{{ feat_img2.alt | default: 'feat-img-2' }}" fetchpriority="low" loading="lazy" />
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Icon Text",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "lorem ipsum"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "lorem ipsum"
    },
    {
      "type": "image_picker",
      "id": "feat_img",
      "label": "Featured Image",
    },
    {
      "type": "image_picker",
      "id": "feat_img2",
      "label": "Featured Image 2",
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "SUPPORT YOUR LIVER NOW →"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "btn_footnotes",
      "label": "Button Footnoes",
      "default": "lorem ipsum dolor"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F4F3E8"
    },
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Background Image",
      "info": "leave blank if not needed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 20
    },
  ],
  "blocks": [
    {
      "type": "block-item",
      "name": "Block Item",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Content",
          "default": "lorem ipsum dolor"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icon Text",
      "category": "Ecomlanders"
    }
  ]
}
{% endschema %}