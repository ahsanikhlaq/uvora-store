{%- comment -%}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  SECTION: Image Marquee
  Purpose: Display sliding images
  Last updated: March 2026
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
{%- endcomment -%}

{% liquid
  assign bg_color = section.settings.bg_color
  assign bg_img = section.settings.bg_img
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  .section-{{ section.id }}-bg {
    background-color: {{ bg_color }};
    {% if bg_img != blank %}
      background-image: url({{ bg_img | image_url }});
      background-size: cover;
      background-repeat: no-repeat;
      background-position: center;
    {% endif %}
  }
  @media screen and (max-width: 980px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
  @media (min-width: 981px) {
    .swiper.image-marquee__contents:before {
      background-image: linear-gradient(90deg, {{ bg_color }} 50%, transparent);
    }
    .swiper.image-marquee__contents:after {
      background-image: linear-gradient(270deg, {{ bg_color }} 50%, transparent);
    }
  }
{%- endstyle -%}

{{ 'el-image-marquee.css' | asset_url | stylesheet_tag }}

<section class="image-marquee section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="image-marquee__wrapper section-wrapper section-{{ section.id }}-padding section-{{ section.id }}-bg">
    <div class="image-marquee__container section-container">
      <div class="swiper image-marquee__contents">
        <div class="swiper-wrapper">
          {% for i in (1..2) %}
            {% for block in section.blocks %}
              <div class="swiper image-marquee__item swiper-slide">
                <img src="{{ block.settings.image | image_url }}" width="100%" height="auto" alt="{{ block.settings.image.alt | default: 'marquee-item' }}" fetchpriority="low" loading="lazy" />
              </div>
            {% endfor %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ "el-image-marquee.js" | asset_url }}" defer></script>

{% schema %}
{
  "name": "Image Marquee",
  "tag": "header",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F4F3E8"
    },
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Background Image",
      "info": "leave blank if not needed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 0
    },
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Marquee",
      "category": "Ecomlanders"
    }
  ]
}
{% endschema %}
