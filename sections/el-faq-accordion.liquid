{%- comment -%}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  SECTION: FAQ Accordion
  Purpose: Display accordion items
  Last updated: January 2026
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
{%- endcomment -%}

{% liquid
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign feat_img = section.settings.feat_img
  assign feat_img_addon = section.settings.feat_img_addon
  assign bg_color_outer = section.settings.bg_color_outer
  assign bg_color = section.settings.bg_color
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  .section-{{ section.id }}-bg { background-color: {{ bg_color }} }
  .faq-accordion.section-{{ section.id }} { background-color: {{ bg_color_outer }} }
  @media screen and (max-width: 980px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
{%- endstyle -%}

{{ 'el-faq-accordion.css' | asset_url | stylesheet_tag }}

<section class="faq-accordion section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="faq-accordion__feat-container">
    {% if feat_img != blank %}
      <img src="{{ feat_img | image_url }}" width="100%" height="auto" class="faq-accordion__feat-img accordion-feat mobile-display" alt="{{ feat_img.alt | default: 'accordion-feat-img' }}" fetchpriority="low" loading="lazy" />
    {% endif %}
    {% if feat_img_addon != blank %}
      <img src="{{ feat_img_addon | image_url }}" width="100%" height="auto" class="faq-accordion__feat-img accordion-feat-addon mobile-display" alt="{{ feat_img_addon.alt | default: 'accordion-feat-img-addon' }}" fetchpriority="low" loading="lazy" />
    {% endif %}
  </div>
  <div class="faq-accordion__wrapper section-wrapper section-{{ section.id }}-padding section-{{ section.id }}-bg">
    <div class="faq-accordion__container section-container">
      <h2 class="faq-accordion__heading section-heading">{{ heading }}</h2>
      <p class="faq-accordion__description section-description">{{ description }}</p>

      <div class="faq-accordion__contents">
        <div class="faq-accordion__contents-left">
          {% assign half = section.blocks.size | divided_by: 2 %}
          {% for block in section.blocks %}
            {% if forloop.index <= half %}
              <div class="faq-accordion__item">
                <h4 class="faq-accordion__item-title section-description">
                  <span>{{ block.settings.title }}</span>
                  {% render 'el-icon', icon: 'circle-plus', class: 'faq-icon icon-plus' %}
                  {% render 'el-icon', icon: 'circle-minus', class: 'faq-icon icon-minus' %}
                </h4>
                <div class="faq-accordion__item-description section-description">
                  {{ block.settings.description }}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      
        <div class="faq-accordion__contents-right">
          {% assign half = section.blocks.size | divided_by: 2 %}
          {% for block in section.blocks %}
            {% if forloop.index > half %}
              <div class="faq-accordion__item">
                <h4 class="faq-accordion__item-title section-description">
                  <span>{{ block.settings.title }}</span>
                  {% render 'el-icon', icon: 'circle-plus', class: 'faq-icon icon-plus' %}
                  {% render 'el-icon', icon: 'circle-minus', class: 'faq-icon icon-minus' %}
                </h4>
                <div class="faq-accordion__item-description section-description">
                  {{ block.settings.description }}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script src="{{ "el-faq-accordion.js" | asset_url }}" defer></script>

{% schema %}
{
  "name": "FAQ Accordion",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "lorem ipsum"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "lorem ipsum dolor"
    },
    {
      "type": "image_picker",
      "id": "feat_img",
      "label": "Featured Image",
    },
    {
      "type": "image_picker",
      "id": "feat_img_addon",
      "label": "Featured Image Addon",
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "bg_color_outer",
      "label": "Background Color (Outer)",
      "default": "#f4f3e8"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#EEEDDD"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding",
      "default": 70
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding",
      "default": 70
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 40
    },
  ],
  "blocks": [
    {
      "type": "accordion-item",
      "name": "Accordion Item",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Title",
          "default": "lorem ipsum"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Content",
          "default": "<p>lorem ipsum dolor</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Accordion",
      "category": "Ecomlanders"
    }
  ]
}
{% endschema %}