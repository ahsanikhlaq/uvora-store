{%- comment -%}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  SECTION: Info Content
  Purpose: Display info content with image
  Last updated: March 2026
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
{%- endcomment -%}

{% liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign bg_color = section.settings.bg_color
  assign divider_color = section.settings.divider_color
  assign bg_img = section.settings.bg_img
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  .section-{{ section.id }}-bg {
    background-color: {{ bg_color }};
    {% if bg_img != blank %}
    background-image: url({{ bg_img | image_url }});
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    {% endif %}
  }
  .info-content__divider {
    background: linear-gradient(90deg, rgba(129, 149, 14, 0.00) 0%, {{ divider_color }} 50%, rgba(129, 149, 14, 0.00) 100%);
  }
  @media screen and (max-width: 980px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ padding_top_mobile }}px;
      padding-bottom: {{ padding_bottom_mobile }}px;
    }
  }
{%- endstyle -%}

{{ 'el-info-content.css' | asset_url | stylesheet_tag }}

<section class="info-content section-{{ section.id }}" id="section-{{ section.id }}">
  <div class="info-content__wrapper section-wrapper section-{{ section.id }}-padding section-{{ section.id }}-bg">
    <div class="info-content__container section-container">
      <p class="info-content__eyebrow section-description">{{ eyebrow }}</p>
      <h2 class="info-content__heading section-heading">{{ heading }}</h2>
      <div class="info-content__divider"></div>

      <div class="info-content__contents">
        {% for block in section.blocks %}
          <div class="info-content__item">
            <img src="{{ block.settings.image | image_url }}" width="100%" height="auto" alt="{{ block.settings.image.alt | default: 'info-img' }}" fetchpriority="low" loading="lazy" />

            <div class="info-content__item-contents">
              <img src="{{ block.settings.icon | image_url }}" width="100%" height="auto" alt="{{ block.settings.icon.alt | default: 'icon-img' }}" fetchpriority="low" loading="lazy" />
              <p class="info-content__item-title section-description">{{ block.settings.title }}</p>
              <p class="info-content__item-content section-description">{{ block.settings.content }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Info Content",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "lorem ipsum"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "lorem ipsum"
    },
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F4F3E8"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Color",
      "default": "#81950E"
    },
    {
      "type": "image_picker",
      "id": "bg_img",
      "label": "Background Image",
      "info": "leave blank if not needed"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding",
      "default": 90
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Top padding (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Bottom padding (Mobile)",
      "default": 70
    },
  ],
  "blocks": [
    {
      "type": "info-item",
      "name": "Info Item",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "lorem ipsum dolor"
        },
        {
          "type": "text",
          "id": "content",
          "label": "Content",
          "default": "lorem ipsum dolor"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Info Content",
      "category": "Ecomlanders"
    }
  ]
}
{% endschema %}