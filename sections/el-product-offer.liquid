          "default": "lorem ipsum"
        },
        { "type": "range", "id": "margin_desktop", "label": "Magin Bottom (Desktop)", "min": 0, "max": 50, "step": 1, "unit": "px", "default": 12 },
        { "type": "range", "id": "margin_mobile", "label": "Magin Bottom (Mobile)", "min": 0, "max": 50, "step": 1, "unit": "px", "default": 8 },
      ]
    },
    {
      "type": "product-title",
      "name": "Product Title",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "info": "leave blank to dynamically get product title"
        },
        { "type": "range", "id": "margin_desktop", "label": "Magin Bottom (Desktop)", "min": 0, "max": 50, "step": 1, "unit": "px", "default": 12 },
        { "type": "range", "id": "margin_mobile", "label": "Magin Bottom (Mobile)", "min": 0, "max": 50, "step": 1, "unit": "px", "default": 8 },
      ]
    },
    {
      "type": "product-eyebrow",
      "name": "Product Eyebrow",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "UVORA"
        },
        { "type": "range", "id": "margin_desktop", "label": "Magin Bottom (Desktop)", "min": 0, "max": 50, "step": 1, "unit": "px", "default": 16 },
        { "type": "range", "id": "margin_mobile", "label": "Magin Bottom (Mobile)", "min": 0, "max": 50, "step": 1, "unit": "px", "default": 12 },
      ]
    },
    {
