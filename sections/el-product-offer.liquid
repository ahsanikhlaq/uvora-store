          "type": "color",
          "id": "color",
          "label": "Color",
          "default": "#B8D514"
        },
        { "type": "range", "id": "margin_desktop", "label": "Magin Bottom (Desktop)", "min": 0, "max": 50, "step": 1, "unit": "px", "default": 16 },
        { "type": "range", "id": "margin_mobile", "label": "Magin Bottom (Mobile)", "min": 0, "max": 50, "step": 1, "unit": "px", "default": 12 },
